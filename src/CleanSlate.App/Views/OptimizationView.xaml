<UserControl x:Class="CleanSlate.App.Views.OptimizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />    <!-- Démarrage -->
            <RowDefinition Height="Auto" /> <!-- Registre -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Optimisation système" Style="{StaticResource HeaderText}" />

        <!-- ================= Programmes au démarrage ================= -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="12" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="4,4,4,8">
                    <TextBlock Text="Programmes au démarrage" Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    <Button Content="Actualiser" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Right" Command="{Binding RefreshStartupCommand}" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding StartupEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6"
                                        Padding="12" Margin="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Command}" Style="{StaticResource MutedText}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding LocationLabel}"
                                                   Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                                   Margin="12,0" />
                                        <Button Grid.Column="2" Content="{Binding ToggleLabel}"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding ToggleCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================= Nettoyage du registre ================= -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Nettoyage du registre" Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold" FontSize="15" />
                <TextBlock Text="{Binding RegistryHonestNotice}" Style="{StaticResource MutedText}"
                           Margin="0,6,0,10" />

                <!-- Liste des entrées orphelines détectées -->
                <ItemsControl ItemsSource="{Binding RegistryIssues}" MaxHeight="140">
                    <ItemsControl.Template>
                        <ControlTemplate>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,2" Foreground="{DynamicResource MutedBrush}" FontSize="12">
                                <Run Text="{Binding ValueName, Mode=OneWay}" Foreground="{DynamicResource TextBrush}" />
                                <Run Text=" — " />
                                <Run Text="{Binding Reason, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding RegistryStatus}" Style="{StaticResource MutedText}"
                           Margin="0,10,0,10" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Analyser le registre" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ScanRegistryCommand}" />
                    <Button Content="Corriger (avec sauvegarde)" Style="{StaticResource AccentButton}"
                            Command="{Binding FixRegistryCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
