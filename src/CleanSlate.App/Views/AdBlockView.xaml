<UserControl x:Class="CleanSlate.App.Views.AdBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bloqueur de publicités" Style="{StaticResource HeaderText}" />

        <!-- Info -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                <TextBlock TextWrapping="Wrap" MaxWidth="700"
                           Style="{StaticResource MutedText}">
                    Bloque les publicités et les traqueurs pour <Bold>tous les navigateurs et toutes les applications</Bold>
                    en ajoutant ~130 000 domaines malveillants au fichier hosts Windows
                    (comme AdGuard Home, sans proxy). Nécessite des droits administrateur.
                    Aucun logiciel supplémentaire installé — désactivation instantanée.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Statut -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="🔴" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                    <Setter Property="Text" Value="🟢" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="AdBlock désactivé" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                        <Setter Property="Text" Value="AdBlock activé" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding BlockedCountText}" FontSize="12"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="{Binding ToggleLabel}"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding ToggleCommand}"
                    Margin="0,0,12,0" />
            <Button Content="🔄 Mettre à jour la liste"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding UpdateListCommand}" />
        </StackPanel>

        <!-- Progression / statut -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="12,10" Margin="0,12,0,0"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏳" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                           FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Source info -->
        <Border Grid.Row="5" VerticalAlignment="Bottom" Margin="0,0,0,0">
            <TextBlock Text="Source : StevenBlack Unified Hosts — github.com/StevenBlack/hosts"
                       Style="{StaticResource MutedText}" FontSize="11" />
        </Border>
    </Grid>
</UserControl>
