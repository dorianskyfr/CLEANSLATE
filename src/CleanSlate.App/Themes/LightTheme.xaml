<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BackgroundBrush"  Color="#F0F2F5" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush"      Color="#1976D2" />
    <SolidColorBrush x:Key="TextBrush"        Color="#1A1A2E" />
    <SolidColorBrush x:Key="MutedBrush"       Color="#6B7280" />
    <SolidColorBrush x:Key="WarningBrush"     Color="#F57C00" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="#388E3C" />
    <SolidColorBrush x:Key="ErrorBrush"       Color="#D32F2F" />
    <SolidColorBrush x:Key="NavSelectedBrush" Color="#1976D2" />
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#E8EDF5" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#D1D5DB" />
</ResourceDictionary>
