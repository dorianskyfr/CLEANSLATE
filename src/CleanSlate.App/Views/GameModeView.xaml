<UserControl x:Class="CleanSlate.App.Views.GameModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Titre -->
            <RowDefinition Height="Auto" />   <!-- Notice -->
            <RowDefinition Height="Auto" />   <!-- Applications -->
            <RowDefinition Height="Auto" />   <!-- Services -->
            <RowDefinition Height="Auto" />   <!-- Statut + bouton -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Mode Jeu" Style="{StaticResource HeaderText}" />

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                <TextBlock Text="{Binding HonestNotice}" Style="{StaticResource MutedText}" MaxWidth="700"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Applications suspendues -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,12,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="⏸️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Applications suspendues (Discord exclu)"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding SuspendedAppsList}"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Services arrêtés -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,8,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🛑" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Services arrêtés temporairement"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding StoppedServicesList}"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12" TextWrapping="Wrap" />
                <TextBlock Text="WSearch (indexation), DiagTrack (télémétrie), SysMain (Superfetch)"
                           Foreground="{DynamicResource MutedBrush}" FontSize="11" FontStyle="Italic"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Statut + bouton -->
        <StackPanel Grid.Row="4" Margin="0,20,0,0">
            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                       FontWeight="SemiBold" FontSize="14" />
            <Button Content="{Binding ToggleLabel}" Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" Margin="0,12,0,0"
                    Command="{Binding ToggleCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
