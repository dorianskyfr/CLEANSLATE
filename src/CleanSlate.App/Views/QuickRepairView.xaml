<UserControl x:Class="CleanSlate.App.Views.QuickRepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- En-tête -->
            <RowDefinition Height="*" />      <!-- Liste des checks -->
            <RowDefinition Height="Auto" />   <!-- Progression + statut -->
            <RowDefinition Height="Auto" />   <!-- Bouton -->
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Réparation rapide" Style="{StaticResource HeaderText}" />
            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0"
                       Text="Diagnostic automatique du système en 6 points. Cliquez sur « Lancer le diagnostic » pour analyser, puis réparez les problèmes détectés." />
        </StackPanel>

        <!-- Liste des checks -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Checks}" x:Name="ChecksList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" Margin="4" CornerRadius="6"
                                    Background="{DynamicResource BackgroundBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icône statut -->
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                               FontSize="18" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />

                                    <!-- Nom + détail -->
                                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding Detail}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" Margin="0,4,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Bouton réparer (visible seulement si CanRepair et statut Warning/Error) -->
                                    <Button Grid.Column="2"
                                            Content="Réparer"
                                            Padding="12,6" Margin="0"
                                            Tag="{Binding}"
                                            Click="RepairButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding CanRepair}" Value="True" />
                                                            <Condition Binding="{Binding Status}" Value="Warning" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding CanRepair}" Value="True" />
                                                            <Condition Binding="{Binding Status}" Value="Error" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Progression -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="6"
                         Minimum="0" Maximum="100"
                         Value="{Binding Progress, Mode=OneWay}"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource AccentBrush}" BorderThickness="0" />
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                       Style="{StaticResource MutedText}" Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Bouton diagnostic -->
        <Button Grid.Row="3" Content="🔍 Lancer le diagnostic" HorizontalAlignment="Right"
                Style="{StaticResource AccentButton}" Margin="0,14,0,0"
                Command="{Binding RunDiagnosticCommand}" />
    </Grid>
</UserControl>
