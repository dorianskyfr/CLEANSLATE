<UserControl x:Class="CleanSlate.App.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Surveillance de la mémoire" Style="{StaticResource HeaderText}" />

        <!-- Jauge d'utilisation -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="20" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource MutedBrush}" FontSize="12"
                           Text="Utilisation de la mémoire physique" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Height="14" Minimum="0" Maximum="100"
                                 Value="{Binding LoadPercent, Mode=OneWay}"
                                 Background="{DynamicResource BackgroundBrush}"
                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0" />
                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" FontWeight="Bold">
                        <Run Text="{Binding LoadPercent, Mode=OneWay, StringFormat={}{0:0}}" />
                        <Run Text="%" />
                    </TextBlock>
                </Grid>

                <UniformGrid Columns="3" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Total" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding TotalDisplay}" Foreground="{DynamicResource TextBrush}"
                                   FontSize="18" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Utilisée" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding UsedDisplay}" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Disponible" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding AvailableDisplay}" Foreground="{DynamicResource TextBrush}"
                                   FontSize="18" FontWeight="Bold" />
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Avertissement honnête -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                <TextBlock Text="{Binding HonestNotice}" Style="{StaticResource MutedText}"
                           MaxWidth="640" />
            </StackPanel>
        </Border>

        <!-- Résultat de la dernière optimisation -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="14,10" Margin="0,12,0,0">
            <TextBlock Text="{Binding LastResult}" Foreground="{DynamicResource TextBrush}"
                       FontSize="13" TextWrapping="Wrap" />
        </Border>

        <!-- Bouton d'optimisation -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock Text="Optimisation en cours…" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource MutedBrush}" FontSize="12"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="🚀 Optimiser la RAM" Style="{StaticResource AccentButton}"
                    Command="{Binding OptimizeCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
