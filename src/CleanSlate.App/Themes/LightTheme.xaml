<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette claire 2.0 — fond doux + accent bleu net -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="#F4F6FA" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush"      Color="#2D6BE0" />
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="#E5EDFB" />
    <SolidColorBrush x:Key="TextBrush"        Color="#17182A" />
    <SolidColorBrush x:Key="MutedBrush"       Color="#626A7C" />
    <SolidColorBrush x:Key="WarningBrush"     Color="#E8830C" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="#2E9E4B" />
    <SolidColorBrush x:Key="ErrorBrush"       Color="#D93B47" />
    <SolidColorBrush x:Key="NavSelectedBrush" Color="#DCE7FB" />
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#EDF1F8" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#DCE0E8" />
</ResourceDictionary>
