<UserControl x:Class="CleanSlate.App.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Titre -->
            <RowDefinition Height="Auto" />   <!-- Info -->
            <RowDefinition Height="Auto" />   <!-- Boutons -->
            <RowDefinition Height="Auto" />   <!-- Statut -->
            <RowDefinition Height="*" />      <!-- Liste mises à jour -->
            <RowDefinition Height="Auto" />   <!-- Lien Windows Update -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Mise à jour des pilotes" Style="{StaticResource HeaderText}" />

        <!-- Info -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                <TextBlock TextWrapping="Wrap" MaxWidth="760" Style="{StaticResource MutedText}">
                    CleanSlate recherche les mises à jour de pilotes via <Bold>Windows Update</Bold>
                    (pilotes signés et certifiés WHQL) et les installe pour vous. Aucun pilote
                    n'est téléchargé depuis une source non officielle.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,8">
            <Button Content="🔍 Rechercher les mises à jour" Style="{StaticResource AccentButton}"
                    Command="{Binding SearchDriverUpdatesCommand}" />
            <Button Content="⬇️ Tout installer" Style="{StaticResource SecondaryButton}"
                    Command="{Binding InstallAllCommand}" />
            <Button Content="Installer la sélection" Style="{StaticResource SecondaryButton}"
                    Command="{Binding InstallSelectedCommand}" />
        </StackPanel>

        <!-- Statut -->
        <TextBlock Grid.Row="3" Text="{Binding UpdateStatus}"
                   Style="{StaticResource MutedText}" Margin="0,0,0,8" />

        <!-- Liste des mises à jour disponibles -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="4">
            <Grid>
                <ListView ItemsSource="{Binding DriverUpdates}" SelectedItem="{Binding SelectedUpdate}"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Mise à jour de pilote" Width="520"
                                            DisplayMemberBinding="{Binding Title}" />
                            <GridViewColumn Header="Taille" Width="100"
                                            DisplayMemberBinding="{Binding SizeDisplay}" />
                            <GridViewColumn Header="Statut" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="{DynamicResource AccentBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="En attente" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                            <Setter Property="Text" Value="✅ Prêt" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Message « à jour » centré quand aucune mise à jour -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding ShowUpToDate, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" />
                    <TextBlock Text="Tous vos pilotes sont à jour."
                               Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lien Windows Update -->
        <Button Grid.Row="5" Content="Ouvrir les mises à jour facultatives de Windows…"
                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                Margin="0,12,0,0" Command="{Binding OpenWindowsUpdateCommand}" />
    </Grid>
</UserControl>
