<UserControl x:Class="CleanSlate.App.Views.GameModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Mode Jeu" Style="{StaticResource HeaderText}" Margin="0,0,0,12" />

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ========================= Suspension d'applications ========================= -->
            <TabItem Header="Suspension d'applications">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                            <TextBlock Text="{Binding HonestNotice}" Style="{StaticResource MutedText}" MaxWidth="700" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="Applications suspendues lors de l'activation :"
                                   Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding SuspendedAppsList}" Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />

                        <!-- Applications personnalisées (persistées entre les sessions) -->
                        <TextBlock Text="Vos applications à suspendre en plus (noms de processus, séparés par des virgules) :"
                                   Style="{StaticResource MutedText}" Margin="0,14,0,0" />
                        <TextBox Text="{Binding CustomProcessesText, UpdateSourceTrigger=LostFocus}"
                                 Padding="8,6" Margin="0,6,0,0" MaxWidth="700" HorizontalAlignment="Left"
                                 MinWidth="420" ToolTip="Exemple : firefox, obs64, Notion" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold" FontSize="14" />
                        <Button Content="{Binding ToggleLabel}" Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Left" Margin="0,12,0,0"
                                Command="{Binding ToggleCommand}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ================================ Overclocking ================================ -->
            <TabItem Header="Overclocking">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0"
                              DataContext="{Binding Overclocking}">
                    <StackPanel>

                        <!-- Avertissement honnête -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                                <TextBlock TextWrapping="Wrap" MaxWidth="780" Style="{StaticResource MutedText}">
                                    CleanSlate détecte votre carte graphique et propose plusieurs profils
                                    de départ (Sûr, Équilibré, Performance). Sur les cartes NVIDIA et AMD
                                    dédiées, CleanSlate <Bold>applique l'overclock lui-même</Bold> (NVAPI /
                                    ADL OverdriveN), avec un bouton « Reset » pour tout annuler. Pour les
                                    autres cartes (Intel notamment), le profil sélectionné est à appliquer
                                    pas à pas dans l'outil officiel (Intel Arc Control / Graphics Command
                                    Center) puis à tester en stabilité.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Sélection GPU -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding Gpus}"
                                      SelectedItem="{Binding SelectedGpu}"
                                      DisplayMemberPath="Name" Padding="8,6" />
                            <Button Grid.Column="1" Content="🔄 Re-détecter" Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
                        </Grid>

                        <!-- Carte détectée -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding GpuName}" Foreground="{DynamicResource TextBrush}"
                                           FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding GpuDetails}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding AutoApplyNote}" Style="{StaticResource MutedText}"
                                           Margin="0,8,0,0" TextWrapping="Wrap" />

                                <!-- Vérification du dernier pilote chez le fabricant -->
                                <StackPanel Margin="0,14,0,0" Visibility="{Binding HasGpu, Converter={StaticResource BoolToVisibility}}">
                                    <Button Content="🔎 Vérifier le dernier pilote disponible (fabricant)"
                                            Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                            Command="{Binding CheckDriverUpdateCommand}" />

                                    <StackPanel Visibility="{Binding HasDriverCheckResult, Converter={StaticResource BoolToVisibility}}"
                                                Margin="0,10,0,0">
                                        <TextBlock Text="{Binding DriverCheckMessage}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                        <UniformGrid Columns="3" Margin="0,8,0,0"
                                                      Visibility="{Binding DriverUpdateAvailable, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Dernière version" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding LatestDriverVersion}" Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="Bold" FontSize="16" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Date de sortie" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding LatestDriverDate}" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Taille" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding LatestDriverSize}" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <Button Content="{Binding OpenLatestDriverLabel}" Style="{StaticResource AccentButton}"
                                                HorizontalAlignment="Left" Margin="0,10,0,0"
                                                Command="{Binding OpenLatestDriverCommand}"
                                                Visibility="{Binding CanOpenLatestDriver, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Profil recommandé -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                                Visibility="{Binding HasProfile, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Profil :" Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}"
                                              SelectedItem="{Binding SelectedProfile}"
                                              DisplayMemberPath="Name" Padding="8,6"
                                              HorizontalAlignment="Left" MinWidth="180"
                                              Visibility="{Binding HasProfiles, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>

                                <UniformGrid Columns="5">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Core Clock" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding CoreOffsetDisplay}" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" FontSize="18" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Memory Clock" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding MemoryOffsetDisplay}" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" FontSize="18" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Power Limit" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding PowerLimitDisplay}" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" FontSize="18" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Temp Limit" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding TempLimitDisplay}" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" FontSize="18" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Ventilation" Style="{StaticResource MutedText}" />
                                        <TextBlock Text="{Binding FanStrategy}" Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </UniformGrid>

                                <!-- Mode personnalisé : curseurs pour fixer ses propres valeurs (bornes sûres) -->
                                <StackPanel Margin="0,14,0,0"
                                            Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="🎛️ Réglages personnalisés (curseurs bornés pour rester sûr) :"
                                               Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" />

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Core Clock" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                        <Slider Grid.Column="1" VerticalAlignment="Center" Margin="6,0"
                                                Minimum="{Binding CoreMin}" Maximum="{Binding CoreMax}"
                                                Value="{Binding CustomCore}" TickFrequency="5" IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="2" Text="{Binding CoreOffsetDisplay}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" />
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Memory Clock" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                        <Slider Grid.Column="1" VerticalAlignment="Center" Margin="6,0"
                                                Minimum="{Binding MemMin}" Maximum="{Binding MemMax}"
                                                Value="{Binding CustomMemory}" TickFrequency="25" IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="2" Text="{Binding MemoryOffsetDisplay}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" />
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Power Limit" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                        <Slider Grid.Column="1" VerticalAlignment="Center" Margin="6,0"
                                                Minimum="{Binding PowerMin}" Maximum="{Binding PowerMax}"
                                                Value="{Binding CustomPower}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="2" Text="{Binding PowerLimitDisplay}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" />
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Temp Limit" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                        <Slider Grid.Column="1" VerticalAlignment="Center" Margin="6,0"
                                                Minimum="{Binding TempMin}" Maximum="{Binding TempMax}"
                                                Value="{Binding CustomTemp}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                        <TextBlock Grid.Column="2" Text="{Binding TempLimitDisplay}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" />
                                    </Grid>
                                </StackPanel>

                                <TextBlock Text="{Binding Rationale}" Style="{StaticResource MutedText}"
                                           Margin="0,14,0,0" />

                                <!-- Étapes -->
                                <TextBlock Text="Étapes à suivre :" Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold" Margin="0,16,0,6" />
                                <ItemsControl ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="•" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource AccentBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="12" TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="🚀 Appliquer l'overclock" Style="{StaticResource AccentButton}"
                                            Command="{Binding ApplyCommand}" Margin="0,0,8,8" />
                                    <Button Content="↩️ Reset" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding ResetCommand}" Margin="0,0,8,8" />
                                    <Button Content="📋 Copier le profil" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CopyProfileCommand}" Margin="0,0,8,8" />
                                </WrapPanel>

                                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="12" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================================ DLSS Enabler ================================ -->
            <TabItem Header="DLSS Enabler">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0"
                              DataContext="{Binding DlssEnabler}">
                    <StackPanel>

                        <!-- Présentation honnête + avertissement anticheat -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎯" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                                <TextBlock Text="{Binding HonestNotice}" Style="{StaticResource MutedText}"
                                           MaxWidth="780" />
                            </StackPanel>
                        </Border>

                        <!-- Barre d'actions : re-scan, recherche, dossier manuel -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🔄 Re-scanner mes jeux"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding ScanGamesCommand}" />
                            <Grid Grid.Column="1" Margin="8,0,0,0">
                                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" VerticalContentAlignment="Center" />
                                <TextBlock Text="🔎 Rechercher un jeu…" Margin="12,0,0,0"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Visibility="{Binding ShowFilterHint, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                            <Button Grid.Column="2" Content="📁 Ajouter un dossier…"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                    Command="{Binding PickFolderCommand}" />
                        </Grid>

                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap" />

                        <!-- Bibliothèque visuelle : jaquettes des jeux détectés -->
                        <ItemsControl ItemsSource="{Binding GamesView}" Margin="0,12,0,0"
                                      Visibility="{Binding HasGames, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="tile" Width="122" Margin="0,0,10,10" Padding="6"
                                            Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                            BorderThickness="2" BorderBrush="Transparent" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectGameCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <Grid Height="159">
                                                <!-- Tuile de remplacement (pas de jaquette / échec de chargement) -->
                                                <Border CornerRadius="6" Background="{DynamicResource BackgroundBrush}">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Initial}" FontSize="42" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="🎮" FontSize="16" HorizontalAlignment="Center"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                <!-- Jaquette (cache local Steam ou CDN, chargée en asynchrone) -->
                                                <Border CornerRadius="6">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding CoverImage}" Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                                <!-- Badge « mod installé » -->
                                                <Border Background="#E61E9E50" CornerRadius="4" Padding="5,2" Margin="5"
                                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                                        Visibility="{Binding Installed, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="✓ DLSS Enabler" FontSize="9" Foreground="White"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <!-- Badge « Xbox Game Pass » (avertissement intégrité du package) -->
                                                <Border Background="#E6107C10" CornerRadius="4" Padding="5,2" Margin="5"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Visibility="{Binding IsGamePass, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="🎮 Game Pass" FontSize="9" Foreground="White"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                       MaxHeight="30" Margin="0,6,0,0" TextAlignment="Center" />
                                            <TextBlock Text="{Binding Source}" FontSize="9"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       TextAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="tile" Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                        <Trigger SourceName="tile" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tile" Property="Background"
                                                    Value="{DynamicResource NavHoverBrush}" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- État du jeu sélectionné + actions -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16"
                                Margin="0,12,0,0"
                                Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedTile.Name}" Foreground="{DynamicResource TextBrush}"
                                           FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedTile.InstallDir}" Style="{StaticResource MutedText}"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="{Binding GameStatusText}" Foreground="{DynamicResource TextBrush}"
                                           FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />

                                <!-- Avertissement Xbox Game Pass : intégrité du package, persistance non garantie -->
                                <TextBlock Text="⚠️ Jeu Xbox Game Pass : Windows peut supprimer les DLL ajoutées lors d'une vérification d'intégrité ou d'une mise à jour."
                                           Foreground="{DynamicResource AccentBrush}" FontSize="12"
                                           Margin="0,8,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding SelectedTile.IsGamePass, Converter={StaticResource BoolToVisibility}}" />

                                <WrapPanel Margin="0,14,0,0">
                                    <Button Content="⬇️ Installer DLSS Enabler" Style="{StaticResource AccentButton}"
                                            Command="{Binding InstallCommand}" Margin="0,0,8,8" />
                                    <Button Content="🗑️ Désinstaller" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding UninstallCommand}" Margin="0,0,8,8" />
                                    <Button Content="🌐 Page du projet (GitHub)" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding OpenProjectPageCommand}" Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
