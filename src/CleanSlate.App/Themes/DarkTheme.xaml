<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette sombre 2.0 — ardoise profonde + accent indigo lumineux -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="#13141C" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#1E2030" />
    <SolidColorBrush x:Key="AccentBrush"      Color="#6C8CFF" />
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="#2A2F4A" />
    <SolidColorBrush x:Key="TextBrush"        Color="#ECEEF6" />
    <SolidColorBrush x:Key="MutedBrush"       Color="#8B90A8" />
    <SolidColorBrush x:Key="WarningBrush"     Color="#FFB454" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="#57C877" />
    <SolidColorBrush x:Key="ErrorBrush"       Color="#F26472" />
    <SolidColorBrush x:Key="NavSelectedBrush" Color="#2A2F4A" />
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#22242F" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#2B2E42" />
</ResourceDictionary>
