<UserControl x:Class="CleanSlate.App.Views.AdBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bloqueur de publicités" Style="{StaticResource HeaderText}" />

        <!-- Info -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top" />
                <TextBlock TextWrapping="Wrap" MaxWidth="700"
                           Style="{StaticResource MutedText}">
                    Bloque les publicités, traqueurs et domaines malveillants pour
                    <Bold>tous les navigateurs et toutes les applications</Bold> en basculant le DNS
                    système vers AdGuard DNS (94.140.14.14 / 94.140.15.15). Léger et
                    instantané — aucun fichier hosts modifié, aucun ralentissement.
                    Nécessite des droits administrateur. Désactivation immédiate :
                    la configuration DNS d'origine est restaurée.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Statut -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="28" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="🔴" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                    <Setter Property="Text" Value="🟢" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Blocage de pub désactivé" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                        <Setter Property="Text" Value="Blocage de pub activé" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding StatusDetails}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Bouton -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="{Binding ToggleLabel}"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding ToggleCommand}" />
        </StackPanel>

        <!-- Progression / statut -->
        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                Padding="12,10" Margin="0,12,0,0"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏳" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AccentBrush}"
                           FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
