<UserControl x:Class="CleanSlate.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Accueil" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />

            <!-- ============================== Santé système ============================== -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Pastille de score -->
                    <Border Grid.Column="0" Width="88" Height="88" CornerRadius="44"
                            Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding HealthScoreDisplay}" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="/100" FontSize="10" Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❤️ Santé système : " Foreground="{DynamicResource TextBrush}"
                                       FontWeight="Bold" FontSize="16" />
                            <TextBlock Text="{Binding HealthRating}" Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="Bold" FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding HealthTips}" Style="{StaticResource MutedText}"
                                   Margin="0,8,0,0" MaxWidth="720" HorizontalAlignment="Left"
                                   Visibility="{Binding HasHealthTips, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ Entretien en 1 clic ============================ -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="🧹 Entretien en 1 clic" Foreground="{DynamicResource TextBrush}"
                               FontWeight="Bold" FontSize="16" />
                    <TextBlock Text="{Binding HonestNotice}" Style="{StaticResource MutedText}"
                               Margin="0,8,0,0" MaxWidth="780" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="🚀 Lancer l'entretien" Style="{StaticResource AccentButton}"
                                Command="{Binding MaintenanceCommand}" />
                        <TextBlock Text="{Binding MaintenanceStatus}" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Visibility="{Binding HasMaintenanceStatus, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <!-- Entretien automatique programmé -->
                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6"
                            Padding="12,10" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding AutoMaintenanceEnabled}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AutoMaintenanceLabel}" TextWrapping="Wrap" MaxWidth="520"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12" />
                            </CheckBox>
                            <ComboBox Width="70" Margin="12,0,0,0" VerticalAlignment="Center"
                                      ItemsSource="{Binding IntervalOptions}"
                                      SelectedItem="{Binding AutoMaintenanceIntervalHours, Mode=TwoWay}" />
                            <TextBlock Text="h" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================== Mon système ============================== -->
            <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                    Padding="20" Margin="0,12,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💻 Mon système" Foreground="{DynamicResource TextBrush}"
                                   FontWeight="Bold" FontSize="16" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="📄 Exporter un rapport" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportReportCommand}"
                                    ToolTip="Enregistre un rapport système texte (santé, matériel, disques) sur le Bureau." />
                            <Button Content="🔄 Actualiser" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,6,16,6">
                            <TextBlock Text="Windows" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding OsName}" Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="Processeur" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding CpuName}" Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,6,16,6">
                            <TextBlock Text="Carte graphique" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding GpuName}" Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="Mémoire vive" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding RamSummary}" Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold" FontSize="14" />
                        </StackPanel>
                        <StackPanel Margin="0,6,16,6">
                            <TextBlock Text="Allumé depuis" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding UptimeDisplay}" Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold" FontSize="14" />
                        </StackPanel>
                    </UniformGrid>
                    <!-- Conseil : redémarrage recommandé après une longue période sans reboot -->
                    <TextBlock Text="{Binding UptimeHint}" Foreground="{DynamicResource AccentBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"
                               Visibility="{Binding HasUptimeHint, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- ================================ Disques ================================ -->
            <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                    Padding="20" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="💾 Disques" Foreground="{DynamicResource TextBrush}"
                               FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding Drives}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                    <ProgressBar Grid.Column="1" Value="{Binding UsedPercent, Mode=OneWay}"
                                                 Maximum="100" Height="10" VerticalAlignment="Center"
                                                 Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
