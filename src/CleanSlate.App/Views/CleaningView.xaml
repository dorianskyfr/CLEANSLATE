<UserControl x:Class="CleanSlate.App.Views.CleaningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- En-tête -->
            <RowDefinition Height="*" />      <!-- Liste des catégories -->
            <RowDefinition Height="Auto" />   <!-- Barre d'actions + statut -->
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Nettoyage de fichiers temporaires" Style="{StaticResource HeaderText}" />
            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0"
                       Text="Analysez d'abord pour obtenir un aperçu. Rien n'est supprimé tant que vous n'avez pas confirmé." />
        </StackPanel>

        <!-- Liste des catégories -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Cleaning.Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="4" CornerRadius="6"
                                    Background="{StaticResource BackgroundBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /> <!-- Case à cocher -->
                                        <ColumnDefinition Width="*" />    <!-- Nom + description -->
                                        <ColumnDefinition Width="Auto" /> <!-- Taille -->
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top" Margin="0,2,12,0" />

                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold" FontSize="14" />
                                            <!-- Badge « admin requis » -->
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                    Visibility="{Binding RequiresAdministrator,
                                                        Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="admin requis" FontSize="10"
                                                           Foreground="{StaticResource WarningBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding RecoverableDisplay}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" FontSize="14"
                                               VerticalAlignment="Center" Margin="12,0,4,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Barre d'actions + statut -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Total + progression -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                    <Run Text="Total récupérable :" Foreground="{StaticResource MutedBrush}" />
                    <Run Text="{Binding Cleaning.TotalRecoverableDisplay, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                </TextBlock>
                <ProgressBar Grid.Column="1" Height="6" Margin="16,0,0,0"
                             Minimum="0" Maximum="100"
                             Value="{Binding Cleaning.ProgressValue, Mode=OneWay}"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
            </Grid>

            <!-- Message de statut -->
            <TextBlock Grid.Row="1" Text="{Binding Cleaning.StatusMessage}"
                       Style="{StaticResource MutedText}" Margin="0,10,0,10" />

            <!-- Boutons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                        Command="{Binding Cleaning.CancelCommand}" />
                <Button Content="Analyser" Style="{StaticResource SecondaryButton}"
                        Command="{Binding Cleaning.ScanCommand}" />
                <Button Content="Nettoyer" Style="{StaticResource AccentButton}"
                        Command="{Binding Cleaning.CleanCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
