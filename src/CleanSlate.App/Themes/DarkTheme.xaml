<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BackgroundBrush"  Color="#1E1F2B" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#2A2B3D" />
    <SolidColorBrush x:Key="AccentBrush"      Color="#4F8CFF" />
    <SolidColorBrush x:Key="TextBrush"        Color="#EDEDF2" />
    <SolidColorBrush x:Key="MutedBrush"       Color="#9A9BB0" />
    <SolidColorBrush x:Key="WarningBrush"     Color="#FFB454" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="#4CAF50" />
    <SolidColorBrush x:Key="ErrorBrush"       Color="#EF5350" />
    <SolidColorBrush x:Key="NavSelectedBrush" Color="#4F8CFF" />
    <SolidColorBrush x:Key="NavHoverBrush"    Color="#1E1F2B" />
    <SolidColorBrush x:Key="BorderBrush"      Color="#3A3B52" />
</ResourceDictionary>
