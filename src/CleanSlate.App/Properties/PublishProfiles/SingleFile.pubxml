<?xml version="1.0" encoding="utf-8"?>
<!--
  Profil de publication : produit UN SEUL fichier CleanSlate.exe autonome.

  Utilisable de deux façons :
    1. En ligne de commande :
         dotnet publish src/CleanSlate.App -c Release -p:PublishProfile=SingleFile
    2. Dans Visual Studio : clic droit sur le projet → Publier → profil « SingleFile ».

  Résultat dans :
    src/CleanSlate.App/bin/Release/net8.0-windows/win-x64/publish/CleanSlate.exe

  L'exe embarque le runtime .NET 8 + WPF : RIEN à installer sur le PC cible.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\net8.0-windows\win-x64\publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <!-- Application autonome : embarque le runtime, aucun prérequis. -->
    <SelfContained>true</SelfContained>

    <!-- Tout regroupé dans un unique .exe. -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!-- Compression de l'exe (~150 Mo → ~70 Mo selon le contenu). -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>

    <!-- Démarrage plus rapide (pré-compilation ReadyToRun). -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!--
      Trimming DÉSACTIVÉ : risqué avec WPF (chargement XAML par réflexion),
      peut casser l'application au runtime. On privilégie la fiabilité.
    -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
