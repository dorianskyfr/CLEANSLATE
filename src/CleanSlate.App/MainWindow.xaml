<Window x:Class="CleanSlate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CleanSlate.App.ViewModels"
        xmlns:views="clr-namespace:CleanSlate.App.Views"
        Title="CleanSlate — Optimisation et nettoyage PC"
        Height="680" Width="1000" MinHeight="520" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <!-- Mappage ViewModel → Vue : le ContentControl affiche la bonne vue selon
         le type du ViewModel sélectionné dans la navigation. -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CleaningViewModel}">
            <views:CleaningView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MemoryViewModel}">
            <views:MemoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DriversViewModel}">
            <views:DriversView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameModeViewModel}">
            <views:GameModeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OptimizationViewModel}">
            <views:OptimizationView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Barre supérieure -->
            <RowDefinition Height="*" />    <!-- Corps -->
        </Grid.RowDefinitions>

        <!-- Barre supérieure -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🧹 CleanSlate" Foreground="{StaticResource TextBrush}"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10"
                            Padding="10,3" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PrivilegeStatus}" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Redémarrer en administrateur"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RestartAsAdminCommand}"
                        Visibility="{Binding ShowElevationButton,
                            Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>

        <!-- Corps : navigation latérale + contenu -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation -->
            <ListBox Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderThickness="0"
                     ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BackgroundBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Glyph}" FontSize="16" Margin="0,0,12,0" />
                            <TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Contenu de la page sélectionnée -->
            <ContentControl Grid.Column="1" Content="{Binding SelectedItem.ViewModel}" />
        </Grid>
    </Grid>
</Window>
